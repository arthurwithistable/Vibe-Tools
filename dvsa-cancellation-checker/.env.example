# Your driving licence number (found on your licence)
LICENCE_NUMBER=your_licence_number_here

# Your theory test pass certificate number
THEORY_TEST_NUMBER=your_theory_pass_number_here

# Test centre name (default: Goodmayes)
TEST_CENTRE=Goodmayes

# How often to check for slots (in minutes). Don't set too low to avoid being blocked.
CHECK_INTERVAL_MINUTES=3

# Earliest acceptable test date (YYYY-MM-DD). Leave empty for any date.
EARLIEST_DATE=

# Latest acceptable test date (YYYY-MM-DD). Leave empty for any date.
LATEST_DATE=

# Preferred days of week (comma-separated, e.g. Monday,Tuesday,Saturday). Leave empty for any day.
PREFERRED_DAYS=

# Run browser in headless mode (true/false). Set to false to watch it work.
HEADLESS=false
